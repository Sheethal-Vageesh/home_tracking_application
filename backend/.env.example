PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/home_tracking
JWT_SECRET=change_this_to_a_long_random_secret
CORS_ORIGIN=http://localhost:5173

# Optional: enable email notifications (otherwise logs to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Optional: enable SMS notifications (Twilio).
# Parent phone should be E.164, e.g. +919876543210
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

